# ─────────────────────────────────────────────────────────────────────────────
# OTP Login Pro — Environment Variables
#
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to source control.
#
# For production (Fly.io): fly secrets set KEY=value
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────

NODE_ENV=development
# development | production | test

APP_VERSION=1.0.0
APP_NAME=OTP Login Pro
LOG_LEVEL=info
# error | warn | info | http | debug

# ── Shopify ───────────────────────────────────────────────────────────────────

# From Shopify Partner dashboard → App setup
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# The public URL where your app is deployed (no trailing slash)
# Local dev: shopify app dev sets this automatically via a tunnel
SHOPIFY_APP_URL=https://your-app.fly.dev

# OAuth scopes (comma-separated, no spaces)
SCOPES=read_customers,write_customers,read_themes,write_themes

# ── MongoDB ───────────────────────────────────────────────────────────────────

# Full connection string including credentials
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# Local:  mongodb://localhost:27017
MONGODB_URI=mongodb+srv://Otp:dfgre1478gxs46gw2688hhddc#@fr625gf@cluster0.7qkpujn.mongodb.net/?appName=Cluster0

# Database name — use separate names per environment
# dev: otp_login_pro_dev | test: otp_login_pro_test | prod: otp_login_pro
MONGODB_DB_NAME=otp_login_pro

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection URL
# Local:       redis://localhost:6379
# Upstash:     rediss://default:password@host.upstash.io:6380
# Fly Redis:   redis://default:password@fly-redis.internal:6379
REDIS_URL=redis://localhost:6379

# Optional password (leave blank if not required)
REDIS_PASSWORD=

# ── Security (MUST change all three in production) ────────────────────────────

# AES-256-GCM key for SMS provider credentials + Multipass secrets.
# Min 32 chars. Generate: openssl rand -hex 32
ENCRYPTION_KEY=change_this_to_a_32_char_min_key_in_production!!

# JWT secret for App Proxy token signing.
# Min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=change_this_to_a_32_char_min_jwt_secret_in_prod!!

# Session cookie encryption secret.
# Min 32 chars. Generate: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_32_char_min_session_secret!!
