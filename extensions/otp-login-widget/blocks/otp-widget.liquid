{% comment %}
  OTP Login Pro — App Embed Block
  target: body → appears in theme editor App Embeds panel with enable/disable toggle.
  Injects on customer login and account pages automatically when enabled.
{% endcomment %}

{%- liquid
  assign channel       = block.settings.channel       | default: 'sms'
  assign widget_type   = block.settings.widget_type   | default: 'popup'
  assign otp_length    = block.settings.otp_length    | default: 6
  assign button_text   = block.settings.button_text   | default: 'Login with OTP'
  assign brand_color   = block.settings.brand_color   | default: '#3B82F6'
  assign dark_mode     = block.settings.dark_mode     | default: false
  assign redirect_url  = block.settings.redirect_url  | default: '/account'
  assign show_on_login     = block.settings.show_on_login     | default: true
  assign show_on_account   = block.settings.show_on_account   | default: false
  assign show_on_all_pages = block.settings.show_on_all_pages | default: false

  assign should_render = false
  if show_on_all_pages
    assign should_render = true
  elsif show_on_login and request.page_type == 'customers/login'
    assign should_render = true
  elsif show_on_account and request.page_type == 'customers/account'
    assign should_render = true
  endif

  if customer and show_on_login
    assign should_render = false
  endif
-%}

{%- unless should_render -%}
  {%- comment %} Page type not configured for widget — skip rendering {%- endcomment %}
{%- else -%}

{{ 'otp-widget.css' | asset_url | stylesheet_tag }}

<div
  id="otp-lp-root-{{ block.id }}"
  class="otp-lp-root{% if dark_mode %} otp-lp-dark{% endif %}"
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  {%- if widget_type == 'inline' -%}
    <div class="otp-lp-inline">
      <div class="otp-lp-modal" role="dialog" aria-label="{{ button_text }}">
        <div id="otp-lp-content-{{ block.id }}"></div>
      </div>
    </div>
  {%- else -%}
    <button
      type="button"
      class="otp-lp-trigger"
      id="otp-lp-trigger-{{ block.id }}"
      aria-haspopup="dialog"
    >
      {{ button_text }}
    </button>
    <div
      class="otp-lp-overlay"
      id="otp-lp-overlay-{{ block.id }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ button_text }}"
    >
      <div class="otp-lp-modal">
        <button type="button" class="otp-lp-close" id="otp-lp-close-{{ block.id }}" aria-label="Close">&#x2715;</button>
        <div id="otp-lp-content-{{ block.id }}"></div>
      </div>
    </div>
  {%- endif -%}
</div>

<script>
  (function() {
    var config = window.OTPLoginProConfig = window.OTPLoginProConfig || {};
    var blockId = {{ block.id | json }};
    var shopDomain = {{ shop.permanent_domain | json }};

    config[blockId] = {
      blockId: blockId,
      shop: shopDomain,
      apiBase: window.location.origin + '/apps/otp-login-pro',
      channel: {{ channel | json }},
      otpLength: {{ otp_length | times: 1 }},
      buttonText: {{ button_text | json }},
      brandColor: {{ brand_color | json }},
      darkMode: {{ dark_mode | json }},
      widgetType: {{ widget_type | json }},
      redirectUrl: {{ redirect_url | json }},
      {% if customer %}
      customerLoggedIn: true,
      customerId: {{ customer.id | json }},
      {% else %}
      customerLoggedIn: false,
      customerId: null,
      {% endif %}
    };
  })();
</script>

<script src="{{ 'otp-widget.js' | asset_url }}" defer></script>

{%- endunless -%}

{% schema %}
{
  "name": "OTP Login Widget",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Pages"
    },
    {
      "type": "checkbox",
      "id": "show_on_login",
      "label": "Show on Login page",
      "default": true,
      "info": "Injects the OTP widget on /account/login"
    },
    {
      "type": "checkbox",
      "id": "show_on_account",
      "label": "Show on Account page",
      "default": false,
      "info": "Injects the OTP widget on /account"
    },
    {
      "type": "checkbox",
      "id": "show_on_all_pages",
      "label": "Show on all pages",
      "default": false,
      "info": "Adds the trigger button site-wide (not recommended for most stores)"
    },
    {
      "type": "header",
      "content": "Authentication"
    },
    {
      "type": "select",
      "id": "channel",
      "label": "Login channel",
      "default": "sms",
      "options": [
        { "value": "sms",   "label": "SMS (Phone)" },
        { "value": "email", "label": "Email" },
        { "value": "both",  "label": "Customer's choice" }
      ]
    },
    {
      "type": "select",
      "id": "otp_length",
      "label": "OTP length",
      "default": "6",
      "options": [
        { "value": "4", "label": "4 digits" },
        { "value": "6", "label": "6 digits" },
        { "value": "8", "label": "8 digits" }
      ]
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "widget_type",
      "label": "Widget type",
      "default": "popup",
      "options": [
        { "value": "popup",  "label": "Popup (modal)" },
        { "value": "inline", "label": "Inline (embedded)" }
      ]
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Login button text",
      "default": "Login with OTP"
    },
    {
      "type": "color",
      "id": "brand_color",
      "label": "Brand color",
      "default": "#3B82F6"
    },
    {
      "type": "checkbox",
      "id": "dark_mode",
      "label": "Dark mode",
      "default": false
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "url",
      "id": "redirect_url",
      "label": "Redirect after login",
      "info": "Where to send the customer after successful OTP login. Leave blank for /account."
    }
  ]
}
{% endschema %}
